{
  "name": "nuxt-synullcenter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --host",
    "agentation:doctor": "agentation-mcp doctor",
    "agentation:mcp": "agentation-mcp server",
    "build": "nuxt build",
    "start": "nuxt preview",
    "generate": "nuxt generate",
    "lint:js": "eslint .",
    "lint:style": "stylelint \"**/*.{css,scss,sass,html,vue}\" --ignore-path .gitignore",
    "lint:prettier": "prettier --check . --ignore-path .prettierignore",
    "lint": "eslint . && stylelint \"**/*.{css,scss,sass,html,vue}\" --ignore-path .gitignore && prettier --check . --ignore-path .prettierignore",
    "lintfix": "prettier --write --list-different . --ignore-path .prettierignore && eslint . --fix && stylelint \"**/*.{css,scss,sass,html,vue}\" --ignore-path .gitignore --fix",
    "prepare": "husky install",
    "test": "jest --config jest.config.cjs"
  },
  "lint-staged": {
    "*.{js,vue}": "eslint --cache",
    "*.{css,scss,sass,html,vue}": "stylelint",
    "*.*": "prettier --check --ignore-path .prettierignore --ignore-unknown"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@iconify-json/solar": "^1.2.1",
    "@iconify-json/tabler": "^1.2.5",
    "@nuxt/scripts": "^0.13.2",
    "@nuxt/ui": "^4.6.0",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/turnstile": "^1.1.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "cobe": "^2.0.1",
    "core-js": "^3.25.3",
    "crypto-js": "^4.2.0",
    "motion-v": "^2.2.0",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-echarts": "^1.0.1",
    "pinia": "^3.0.4",
    "sass": "^1.79.5",
    "tailwindcss": "^4.2.2",
    "vue-chartjs": "^5.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.19.1",
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@eslint/js": "^8.57.1",
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/stylelint-module": "^4.1.0",
    "@pinia/nuxt": "^0.11.3",
    "@vue/test-utils": "^2.0.0",
    "agentation": "^3.0.2",
    "agentation-mcp": "^1.2.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-jest": "^29.1.2",
    "eslint": "^8.24.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-jest": "^27.0.4",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-vue": "^9.5.1",
    "globals": "^17.4.0",
    "husky": "^8.0.1",
    "jest": "^29.1.2",
    "jest-environment-jsdom": "^29.1.2",
    "lint-staged": "^13.0.3",
    "postcss": "^8.4.17",
    "postcss-html": "^1.5.0",
    "prettier": "^2.7.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "stylelint": "^14.13.0",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-recommended-vue": "^1.4.0",
    "stylelint-config-standard": "^28.0.0",
    "typescript": "5.9.3",
    "vue-jest": "^3.0.4"
  },
  "packageManager": "pnpm@10.17.1"
}
