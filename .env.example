# 可选：自定义中间件 / BFF 单独转发后端，配置后优先使用
# MIDDLEWARE_BACKEND_URL=http://127.0.0.1:8801

# 可选：渐进式拆分时，指定外部业务中间件地址（例如 Deno）
# 仅对 MIDDLEWARE_SERVICE_SCOPES 命中的模块生效
# MIDDLEWARE_SERVICE_URL=http://127.0.0.1:8802
# MIDDLEWARE_SERVICE_SCOPES=cart,products

# 可选：Nuxt 请求外部业务中间件时额外携带的校验请求头（JSON 数组）
# 支持格式同 MIDDLEWARE_BACKEND_HEADERS
# MIDDLEWARE_SERVICE_HEADERS=[{"name":"x-middleware-verify","value":"replace-with-your-secret"}]

# 可选：BFF 转发到后端时额外携带的校验请求头（JSON 数组）
# 支持格式：[{"name":"x-backend-verify","value":"replace-with-your-secret"}]
# 也支持：[["x-backend-verify","replace-with-your-secret"]]
# MIDDLEWARE_BACKEND_HEADERS=[{"name":"x-backend-verify","value":"replace-with-your-secret"}]

# 默认魔方财务后端地址（未单独配置中间件后端时使用）
BACKEND_URL=http://127.0.0.1:8800

# 当前站点对外访问地址，用于生成前台链接/回跳地址
NUXT_PUBLIC_BASE_URL=http://localhost:3000

# Cloudflare Turnstile（登录/注册/重置密码/安全操作会用到）
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Nuxt 会话密钥，生产环境请替换成 32 位以上随机字符串
NUXT_SESSION_PASSWORD=change-this-to-a-32-character-random-secret

# 官方网站地址
NUXT_PUBLIC_OFFICIAL_SITE_URL=http://example.com

# 兼容别名（按需二选一，不必重复配置）
# BACK_URL=
# NUXT_BACK_URL=
# BASE_URL=
